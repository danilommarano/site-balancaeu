# ============================================
# Pulso — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://pulso:pulso@localhost:5432/pulso?schema=public"

# Docker — PostgreSQL
POSTGRES_USER="pulso"
POSTGRES_PASSWORD="pulso"
POSTGRES_DB="pulso"
DB_PORT=5432

# Autenticação (Lucia Auth)
AUTH_SECRET="gerar-com-openssl-rand-base64-32"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLIC_KEY="pk_test_..."

# Cloudflare R2 (Storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="pulso-uploads"
R2_PUBLIC_URL=""

# Resend (Email)
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@pulso.app"

# App
PUBLIC_APP_NAME="Pulso"
PUBLIC_APP_URL="http://localhost:5173"
NODE_ENV="development"
PORT=3000
ORIGIN="http://localhost:3000"
