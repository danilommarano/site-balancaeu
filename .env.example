# ============================================
# BalancaEu — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://pulso:pulso@localhost:5432/pulso?schema=public"

# Docker — PostgreSQL
POSTGRES_USER="pulso"
POSTGRES_PASSWORD="pulso"
POSTGRES_DB="pulso"
DB_PORT=5432

# Autenticação
AUTH_SECRET="gerar-com-openssl-rand-base64-32"

# ─── OAuth Google ───────────────────────────────
# https://console.cloud.google.com → Credenciais → Criar credenciais OAuth 2.0
# Origem JS autorizada:  http://localhost:5173
# URI de redirecionamento: http://localhost:5173/login/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── OAuth Apple ────────────────────────────────
# https://developer.apple.com/account/resources/identifiers/list/serviceId
# APPLE_CLIENT_ID   = Services ID (ex: com.balancaeu.web)
# APPLE_TEAM_ID     = Team ID da conta Apple Developer
# APPLE_KEY_ID      = Key ID do "Sign in with Apple" key (.p8)
# APPLE_PRIVATE_KEY = conteúdo do arquivo .p8 (PEM) — substitua newlines por \n
#                     ex: "-----BEGIN PRIVATE KEY-----\nMIG...\n-----END PRIVATE KEY-----"
# Return URL: http://localhost:5173/login/apple/callback  (em prod: https)
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLIC_KEY="pk_test_..."

# Cloudflare R2 (Storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="balancaeu-uploads"
R2_PUBLIC_URL=""

# Resend (Email)
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@balancaeu.app"

# App
PUBLIC_APP_NAME="BalancaEu"
PUBLIC_APP_URL="http://localhost:5173"
NODE_ENV="development"
PORT=3000
ORIGIN="http://localhost:3000"
