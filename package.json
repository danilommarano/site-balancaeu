{
  "name": "pulso",
  "version": "0.1.0",
  "description": "Pulso — Plataforma SaaS white-label para escolas de dança e centros culturais",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "docker:dev": "docker compose --profile dev up -d",
    "docker:dev:down": "docker compose --profile dev down",
    "docker:dev:logs": "docker compose --profile dev logs -f app-dev",
    "docker:prod": "docker compose up -d --build app db",
    "docker:prod:down": "docker compose down",
    "docker:prod:logs": "docker compose logs -f app",
    "docker:db": "docker compose up -d db",
    "docker:db:down": "docker compose down db",
    "docker:seed": "docker compose exec app-dev npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.5.0",
    "prisma": "^6.0.0",
    "svelte": "^5.55.1",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.3",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1039.0",
    "@aws-sdk/s3-request-presigner": "^3.1039.0",
    "@prisma/client": "^6.0.0",
    "@types/qrcode": "^1.5.6",
    "@vladmandic/face-api": "^1.7.15",
    "apexcharts": "^5.10.6",
    "arctic": "^3.7.0",
    "bcrypt": "^6.0.0",
    "date-fns": "^4.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-svelte": "^0.468.0",
    "qrcode": "^1.5.4",
    "resend": "^6.10.0",
    "zod": "^3.23.0"
  }
}
